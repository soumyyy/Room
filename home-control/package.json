{
  "name": "home-control",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node ./node_modules/expo/bin/cli start --dev-client",
    "android": "node ./node_modules/expo/bin/cli run:android",
    "ios": "node ./node_modules/expo/bin/cli run:ios",
    "web": "node ./node_modules/expo/bin/cli start --web",
    "backend": "node --env-file=backend/.env backend/server.mjs",
    "backend:dev": "node --watch --env-file=backend/.env backend/server.mjs"
  },
  "dependencies": {
    "@react-native-community/slider": "5.0.1",
    "buffer": "^6.0.3",
    "crypto-js": "^4.2.0",
    "expo": "~54.0.33",
    "expo-dev-client": "^55.0.27",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-tcp-socket": "^6.4.1",
    "react-native-udp": "^4.1.7"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.72.8",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@expo/metro-config": "54.0.14"
  }
}
